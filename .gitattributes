/.yarn/releases/** binary
/.yarn/plugins/** binary

# Normalise all text files to LF on commit
* text=auto eol=lf

# Force these to always be LF
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf

# Treat binary files as binary (no line ending conversion)
*.png  binary
*.jpg  binary
*.ico  binary
*.pdf  binary
*.svg  binary